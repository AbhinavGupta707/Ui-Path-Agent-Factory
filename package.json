{
  "name": "ui-path-agent-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm --workspace @agent-factory/shared-contracts run build && npm --workspace @agent-factory/customer360-metrics run build && npm run typecheck --workspaces --if-present",
    "lint": "node scripts/privacy-security-scan.mjs && npm run lint:workspaces",
    "lint:workspaces": "npm run lint --workspaces --if-present",
    "smoke": "npm run build && npm test",
    "demo:reset": "node scripts/reset-demo-state.mjs",
    "demo:scan": "node scripts/privacy-security-scan.mjs",
    "demo:scan:strict": "node scripts/privacy-security-scan.mjs --strict",
    "setup:live": "node scripts/setup-live-env.mjs",
    "dev:live": "node scripts/dev-live.mjs",
    "smoke:demo": "node scripts/smoke-demo.mjs",
    "smoke:build-worker": "npm --workspace @agent-factory/build-worker run smoke",
    "smoke:customer360": "npm --workspace @agent-factory/customer360-template run smoke",
    "dev:console": "npm run dev -w @agent-factory/factory-console",
    "dev:customer360": "npm run dev -w @agent-factory/customer360-template",
    "dev:api": "npm run dev -w @agent-factory/factory-api",
    "dev:worker": "npm run dev -w @agent-factory/build-worker"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
