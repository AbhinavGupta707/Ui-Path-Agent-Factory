{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-factory.local/uipath/action-center/approval-contracts.schema.json",
  "title": "Agent Factory Action Center approval contracts",
  "type": "object",
  "required": ["status", "platformMode", "environment", "actionCenter", "approvalTypes"],
  "properties": {
    "status": {
      "const": "proposal-only"
    },
    "platformMode": {
      "const": "uipath-ready"
    },
    "environment": {
      "type": "object",
      "required": ["organization", "tenant", "folderName", "folderKey", "folderId"]
    },
    "actionCenter": {
      "type": "object",
      "required": ["cliSurface", "creationSurface", "liveMutationPolicy"]
    },
    "approvalTypes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/approvalType"
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "required": ["field", "label", "source", "type", "required"]
    },
    "outcome": {
      "type": "object",
      "required": ["decision", "approvalTaskStatus", "automationRequestStatus", "maestroRoute"]
    },
    "approvalType": {
      "type": "object",
      "required": [
        "approvalType",
        "taskTitle",
        "createWhen",
        "reviewerVisibleFields",
        "decisionFormFields",
        "outcomes",
        "requiredDecisionPayload",
        "dataServiceMirror",
        "maestroTransitions",
        "auditEvents",
        "sampleTaskPayload",
        "sampleDecisionPayload"
      ],
      "properties": {
        "approvalType": {
          "enum": ["scope", "release"]
        },
        "taskTitle": {
          "type": "string"
        },
        "reviewerVisibleFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "decisionFormFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "outcomes": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/outcome"
          }
        }
      }
    }
  }
}
