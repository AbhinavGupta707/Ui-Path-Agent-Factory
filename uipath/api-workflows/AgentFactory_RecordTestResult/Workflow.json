{
  "document": {
    "dsl": "1.0.0",
    "name": "AgentFactory_RecordTestResult",
    "version": "0.0.1",
    "namespace": "agent-factory",
    "metadata": {
      "description": "No-auth local HTTP workflow that records test gate results as a Factory API build status update.",
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {},
            "title": "Variables"
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "operationId": {
            "type": "string",
            "description": "Idempotency key. Retries must reuse the same value."
          },
          "requestId": {
            "type": "string",
            "description": "AutomationRequest.request_id correlation key."
          },
          "platformMode": {
            "type": "string",
            "default": "uipath-ready",
            "description": "local-simulated, uipath-ready, or uipath-live. Use uipath-live only after real platform execution."
          },
          "apiWorkflowExecutionId": {
            "type": "string",
            "description": "Live UiPath API Workflow execution id. Set only after Automation Cloud execution."
          },
          "folderKey": {
            "type": "string",
            "default": "cba41e19-47cc-4a0a-bf73-de88b60a61be"
          },
          "folderId": {
            "type": "integer",
            "default": 7986306
          },
        "factoryApiBaseUrl": {
          "type": "string",
          "default": "http://localhost:8787",
          "description": "Base URL for Factory API test result callbacks. Defaults to local HTTP; live Automation Cloud runs must use an approved HTTPS tunnel or hosted endpoint."
        },
          "bridgeToken": {
            "type": "string",
            "default": "",
            "description": "Optional shared bridge token sent as x-agent-factory-bridge-token when the trusted HTTPS bridge requires it."
          },
          "buildRunId": {
            "type": "string"
          },
          "qualityGateDecision": {
            "type": "string",
            "description": "passed, failed, blocked, or waiver_requested."
          },
          "testResult": {
            "type": "object",
            "additionalProperties": true,
            "default": {},
            "description": "Redacted test evidence summary."
          }
        },
        "required": [
          "operationId",
          "requestId",
          "buildRunId",
          "qualityGateDecision"
        ],
        "title": "Inputs"
      }
    }
  },
  "output": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "string"
          },
          "requestId": {
            "type": "string"
          },
          "operationId": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          },
          "ok": {
            "type": "boolean"
          },
          "body": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "title": "Outputs"
      }
    }
  },
  "do": [
    {
      "Sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": {
                "as": "${$input}"
              },
              "export": {
                "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
              },
              "metadata": {
                "activityType": "Assign",
                "displayName": "Workflow start",
                "fullName": "Assign",
                "isTransparent": true
              }
            }
          },
          {
            "TestStatusPayload": {
              "run": {
                "script": {
                  "code": "const result = $workflow.input.testResult ?? {};\nconst decision = $workflow.input.qualityGateDecision;\nconst status = decision === 'passed' ? 'awaiting_release_approval' : decision === 'failed' ? 'tests_failed' : 'blocked';\nreturn {\n  status,\n  platformMode: $workflow.input.platformMode ?? result.platformMode,\n  api_workflow_execution_id: $workflow.input.apiWorkflowExecutionId ?? result.api_workflow_execution_id,\n  worker_id: result.worker_id ?? 'uipath-api-workflow',\n  generated_files_json: Array.isArray(result.generated_files_json) ? result.generated_files_json : [],\n  logs_uri: result.logs_uri\n};",
                  "language": "javascript",
                  "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                }
              },
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"TestStatusPayload\": $output } }"
              },
              "metadata": {
                "activityType": "JsInvoke",
                "displayName": "Test status payload",
                "fullName": "JsInvoke"
              }
            }
          },
          {
            "HttpRequest_1": {
              "call": "UiPath.Http",
              "with": {
                "connector": "uipath-uipath-http",
                "connectionId": "ImplicitConnection",
                "connectionResourceId": "ImplicitConnection",
                "method": "POST",
                "endpoint": "/http-request",
                "bodyParameters": {
                  "authentication": "manual",
                  "method": "PATCH",
                  "url": "${$workflow.input.factoryApiBaseUrl + '/api/builds/' + $workflow.input.buildRunId + '/status'}",
                  "headers": {
                    "content-type": "application/json",
                    "x-agent-factory-operation-id": "${$workflow.input.operationId}",
                    "x-agent-factory-bridge-token": "${$workflow.input.bridgeToken}"
                  },
                  "body": "${$context.outputs.TestStatusPayload}"
                }
              },
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"http_request_1\": $output } }"
              },
              "metadata": {
                "fullName": "Connector",
                "activityType": "Connector",
                "displayName": "Record test result",
                "uiPathActivityTypeId": "5c4cc855-b42a-37e6-b910-de8588998fce",
                "assemblyQualifiedName": "Connector",
                "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-http\",\"activityType\":\"Curated\",\"objectName\":\"http-request\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"http-request\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/http-request\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_http-request\"}}"
              }
            }
          },
          {
            "Response_1": {
              "response": "${{ workflow: 'AgentFactory_RecordTestResult', requestId: $workflow.input.requestId, operationId: $workflow.input.operationId, statusCode: $context.outputs.http_request_1.statusCode, ok: $context.outputs.http_request_1.ok, body: $context.outputs.http_request_1.content, buildRunId: $workflow.input.buildRunId, qualityGateDecision: $workflow.input.qualityGateDecision }}",
              "markJobAsFailed": false,
              "then": "end",
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"Response_1\": $output } }"
              },
              "metadata": {
                "activityType": "Response",
                "displayName": "Response",
                "fullName": "Response"
              }
            }
          }
        ],
        "metadata": {
          "activityType": "Sequence",
          "displayName": "Sequence",
          "fullName": "Sequence"
        }
      }
    }
  ],
  "evaluate": {
    "mode": "strict",
    "language": "javascript"
  }
}
