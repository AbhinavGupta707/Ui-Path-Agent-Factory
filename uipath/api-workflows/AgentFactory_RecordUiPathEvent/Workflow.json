{
  "document": {
    "dsl": "1.0.0",
    "name": "AgentFactory_RecordUiPathEvent",
    "version": "0.0.1",
    "namespace": "agent-factory",
    "metadata": {
      "description": "No-auth local HTTP workflow that records live UiPath orchestration evidence in the Factory API.",
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {},
            "title": "Variables"
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "operationId": {
            "type": "string",
            "description": "Idempotency/correlation key for the live evidence callback."
          },
          "requestId": {
            "type": "string",
            "description": "AutomationRequest.request_id correlation key."
          },
          "platformMode": {
            "type": "string",
            "default": "uipath-live",
            "description": "This workflow records live evidence and should use uipath-live only after real platform execution."
          },
          "folderKey": {
            "type": "string",
            "default": "cba41e19-47cc-4a0a-bf73-de88b60a61be"
          },
          "folderId": {
            "type": "integer",
            "default": 7986306
          },
          "factoryApiBaseUrl": {
            "type": "string",
            "default": "http://localhost:8787",
            "description": "Base URL for Factory API evidence callbacks. Live Automation Cloud runs must use an approved HTTPS tunnel or hosted endpoint."
          },
          "bridgeToken": {
            "type": "string",
            "default": "",
            "description": "Optional shared bridge token sent as x-agent-factory-bridge-token when the trusted HTTPS bridge requires it."
          },
          "event": {
            "type": "object",
            "additionalProperties": true,
            "description": "UiPathEvidenceEvent payload without raw secrets, prompts, or trace payloads."
          }
        },
        "required": [
          "operationId",
          "requestId",
          "event"
        ],
        "title": "Inputs"
      }
    }
  },
  "output": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "string"
          },
          "requestId": {
            "type": "string"
          },
          "operationId": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          },
          "ok": {
            "type": "boolean"
          },
          "body": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "title": "Outputs"
      }
    }
  },
  "do": [
    {
      "Sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": {
                "as": "${$input}"
              },
              "export": {
                "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
              },
              "metadata": {
                "activityType": "Assign",
                "displayName": "Workflow start",
                "fullName": "Assign",
                "isTransparent": true
              }
            }
          },
          {
            "EvidencePayload": {
              "run": {
                "script": {
                  "code": "const event = $workflow.input.event ?? {};\nreturn {\n  ...event,\n  platformMode: $workflow.input.platformMode ?? event.platformMode ?? 'uipath-live'\n};",
                  "language": "javascript",
                  "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                }
              },
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"EvidencePayload\": $output } }"
              },
              "metadata": {
                "activityType": "JsInvoke",
                "displayName": "Evidence payload",
                "fullName": "JsInvoke"
              }
            }
          },
          {
            "HttpRequest_1": {
              "call": "UiPath.Http",
              "with": {
                "connector": "uipath-uipath-http",
                "connectionId": "ImplicitConnection",
                "connectionResourceId": "ImplicitConnection",
                "method": "POST",
                "endpoint": "/http-request",
                "bodyParameters": {
                  "authentication": "manual",
                  "method": "POST",
                  "url": "${$workflow.input.factoryApiBaseUrl + '/api/requests/' + $workflow.input.requestId + '/uipath-event'}",
                  "headers": {
                    "content-type": "application/json",
                    "x-agent-factory-operation-id": "${$workflow.input.operationId}",
                    "x-agent-factory-bridge-token": "${$workflow.input.bridgeToken}"
                  },
                  "body": "${$context.outputs.EvidencePayload}"
                }
              },
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"http_request_1\": $output } }"
              },
              "metadata": {
                "fullName": "Connector",
                "activityType": "Connector",
                "displayName": "Record UiPath evidence",
                "uiPathActivityTypeId": "5c4cc855-b42a-37e6-b910-de8588998fce",
                "assemblyQualifiedName": "Connector",
                "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-http\",\"activityType\":\"Curated\",\"objectName\":\"http-request\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"http-request\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/http-request\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_http-request\"}}"
              }
            }
          },
          {
            "Response_1": {
              "response": "${{ workflow: 'AgentFactory_RecordUiPathEvent', requestId: $workflow.input.requestId, operationId: $workflow.input.operationId, statusCode: $context.outputs.http_request_1.statusCode, ok: $context.outputs.http_request_1.ok, body: $context.outputs.http_request_1.content }}",
              "markJobAsFailed": false,
              "then": "end",
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"Response_1\": $output } }"
              },
              "metadata": {
                "activityType": "Response",
                "displayName": "Response",
                "fullName": "Response"
              }
            }
          }
        ],
        "metadata": {
          "activityType": "Sequence",
          "displayName": "Sequence",
          "fullName": "Sequence"
        }
      }
    }
  ],
  "evaluate": {
    "mode": "strict",
    "language": "javascript"
  }
}
